generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                   String               @id @default(uuid())
  name                 String
  documentNumber       String               @unique @map("document_number")
  plan                 TenantPlan           @default(starter) @map("plan_type")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  subscriptionStatus   SubscriptionStatus   @default(trialing) @map("subscription_status")
  stripeCustomerId     String?              @unique @map("stripe_customer_id")
  stripeSubscriptionId String?              @unique @map("stripe_subscription_id")
  maxUsers             Int                  @default(1) @map("max_users")
  maxCustomers         Int                  @default(300) @map("max_customers")
  maxInvoices          Int                  @default(1000) @map("max_invoices")
  supportLevel         SupportLevel         @default(standard) @map("support_level")
  onboardingTier       OnboardingTier       @default(basic) @map("onboarding_tier")
  stripePriceId        String?              @map("stripe_price_id")
  currentPeriodEnd     DateTime?            @map("current_period_end")
  accentColor          String?              @map("accent_color")
  logoUrl              String?              @map("logo_url")
  primaryColor         String?              @map("primary_color")
  activityLogs         ActivityLog[]
  billingFlows         BillingFlow[]
  communicationLogs    CommunicationLog[]
  communications       Communication[]
  customers            Customer[]
  financialContacts    FinancialContact[]
  invoiceInstallments  InvoiceInstallment[]
  invoices             Invoice[]
  paymentPromises      PaymentPromise[]
  tasks                Task[]
  users                TenantUser[]

  @@map("tenants")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  fullName          String           @map("full_name")
  password          String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  googleId          String?          @unique @map("google_id")
  emailVerified     Boolean          @default(false) @map("email_verified")
  isActive          Boolean          @default(false) @map("is_active")
  mfaEnabled        Boolean          @default(false) @map("mfa_enabled")
  mfaSecret         String?          @map("mfa_secret")
  activityLogs      ActivityLog[]
  customerNotes     CustomerNote[]
  assignedCustomers Customer[]
  paymentPromises   PaymentPromise[]
  tasks             Task[]
  tenants           TenantUser[]

  @@map("users")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   @default("operator")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model Customer {
  id                String             @id @default(uuid())
  tenantId          String             @map("tenant_id")
  name              String
  documentNumber    String             @map("document_number")
  status            String             @default("active")
  email             String?
  phone             String?
  address           String?
  notes             String?
  tags              String?
  assignedUserId    String?            @map("assigned_user_id")
  customData        String?            @map("custom_data")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  communicationLogs CommunicationLog[]
  communications    Communication[]
  customerNotes     CustomerNote[]
  assignee          User?              @relation(fields: [assignedUserId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialContacts FinancialContact[]
  invoices          Invoice[]
  tasks             Task[]

  @@index([tenantId])
  @@index([assignedUserId])
  @@map("customers")
}

model FinancialContact {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  name       String
  email      String
  phone      String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("financial_contacts")
}

model CustomerNote {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  userId     String   @map("user_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

model Invoice {
  id                  String               @id @default(uuid())
  tenantId            String               @map("tenant_id")
  customerId          String               @map("customer_id")
  invoiceNumber       String               @map("invoice_number")
  amount              Float
  balanceDue          Float                @map("balance_due")
  dueDate             DateTime             @map("due_date")
  issueDate           DateTime             @default(now()) @map("issue_date")
  status              String               @default("OPEN")
  externalReferenceId String?              @map("external_reference_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  paidAt              DateTime?            @map("paid_at")
  paidAmount          Float?               @map("paid_amount")
  canceledAt          DateTime?            @map("canceled_at")
  cancelReason        String?              @map("cancel_reason")
  promiseDate         DateTime?            @map("promise_date")
  promiseNote         String?              @map("promise_note")
  fineAmount          Float                @default(0) @map("fine_amount")
  interestAmount      Float                @default(0) @map("interest_amount")
  updatedAmount       Float                @default(0) @map("updated_amount")
  communicationLogs   CommunicationLog[]
  communications      Communication[]
  installments        InvoiceInstallment[]
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentPromises     PaymentPromise[]
  tasks               Task[]

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, customerId, status])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceInstallment {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  invoiceId         String   @map("invoice_id")
  installmentNumber Int      @map("installment_number")
  amount            Float
  dueDate           DateTime @map("due_date")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_installments")
}

model BillingFlow {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  rules       String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("billing_flows")
}

model Communication {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  customerId   String    @map("customer_id")
  invoiceId    String?   @map("invoice_id")
  channel      String
  messageType  String    @map("message_type")
  content      String
  status       String    @default("queued")
  externalId   String?   @map("external_id")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  sentAt       DateTime  @default(now()) @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt])
  @@index([externalId])
  @@map("communications")
}

model MessageQueue {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  channel             String
  to                  String
  subject             String?
  body                String
  metadata            String?
  status              String    @default("queued")
  retryCount          Int       @default(0) @map("retry_count")
  maxRetries          Int       @default(3) @map("max_retries")
  errorLog            String?   @map("error_log")
  scheduledAt         DateTime  @default(now()) @map("scheduled_at")
  sentAt              DateTime? @map("sent_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  idempotencyKey      String?   @unique @map("idempotency_key")
  isDlq               Boolean   @default(false) @map("is_dlq")
  fallbackFrom        String?   @map("fallback_from")
  nextRetryAt         DateTime? @map("next_retry_at")
  processingStartedAt DateTime? @map("processing_started_at")

  @@index([status, retryCount])
  @@index([tenantId])
  @@index([idempotencyKey])
  @@index([isDlq])
  @@map("message_queue")
}

model PaymentPromise {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  invoiceId    String   @map("invoice_id")
  userId       String   @map("user_id")
  promisedDate DateTime @map("promised_date")
  amount       Float
  notes        String?
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@index([tenantId, promisedDate])
  @@map("payment_promises")
}

model ActivityLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

model Task {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  customerId  String    @map("customer_id")
  invoiceId   String?   @map("invoice_id")
  title       String
  description String?
  status      String    @default("pending")
  dueDate     DateTime  @map("due_date")
  assigneeId  String?   @map("assignee_id")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, dueDate])
  @@index([assigneeId, status])
  @@map("tasks")
}

/// Tracks each communication generated by the Intelligent Collection Workflow.
/// Supports manual (whatsapp_manual, email_manual) and future automated modes.
/// idempotency: (tenantId, invoiceId, ruleType, channel) prevents duplicate entries.
model CommunicationLog {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  customerId   String    @map("customer_id")
  invoiceId    String?   @map("invoice_id")
  ruleType     String    @map("rule_type")
  channel      String
  message      String
  status       String    @default("pending")
  scheduledFor DateTime  @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  metadata     String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceId, ruleType, channel], name: "collection_log_idempotency")
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, customerId])
  @@index([tenantId, ruleType])
  @@map("communication_logs")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("email_verification_tokens")
}

model RateLimit {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime @map("reset_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([resetAt])
  @@map("rate_limits")
}

/// Stores processed Stripe event IDs to prevent duplicate webhook processing.
/// An event is safe to process only once — if the id already exists here, skip it.
model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_events")
}

model Lead {
  id            String   @id @default(uuid())
  name          String
  company       String
  email         String
  whatsapp      String
  monthlyVolume String   @map("monthly_volume")
  source        String   @default("lp_fluxeer")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("leads")
}

enum TenantPlan {
  starter
  pro
  scale
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum SupportLevel {
  standard
  priority
  vip
}

enum OnboardingTier {
  basic
  assisted
  concierge
}
