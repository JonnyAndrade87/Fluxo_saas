generator client {
  provider = "prisma-client-js"
}

// Local testing DB. Change provider to "postgresql" for production with Supabase/Vercel
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE & IDENTITY (MULTI-TENANT FOUNDATION)
// ==========================================

model Tenant {
  id              String   @id @default(uuid())
  name            String
  documentNumber  String   @unique @map("document_number")
  planType        String   @default("starter") @map("plan_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relationships
  users              TenantUser[]
  customers          Customer[]
  financialContacts  FinancialContact[]
  invoices           Invoice[]
  invoiceInstallments InvoiceInstallment[]
  billingFlows       BillingFlow[]
  communications     Communication[]
  paymentPromises    PaymentPromise[]
  activityLogs       ActivityLog[]
  tasks              Task[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String   @map("full_name")
  password  String?  // Hashed password for Credentials provider
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  tenants           TenantUser[]
  paymentPromises   PaymentPromise[]
  activityLogs      ActivityLog[]
  assignedCustomers Customer[]
  customerNotes     CustomerNote[]
  tasks             Task[]

  @@map("users")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   @default("operator") // admin, operator, viewer
  createdAt DateTime @default(now()) @map("created_at")

  // Foreign Keys
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

// ==========================================
// BILLING & CUSTOMERS
// ==========================================

model Customer {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  name            String
  documentNumber  String   @map("document_number")
  status          String   @default("active") // active, inactive, blocklisted
  email           String?  // Main company email
  phone           String?  // Main company phone/whatsapp
  address         String?  // Company address
  notes           String?  // General internal observations
  tags            String?  // Comma separated tags for segmentation
  assignedUserId  String?  @map("assigned_user_id") // internal responsible
  customData      String?  @map("custom_data") // SQLite JSONB fallback
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignee User?  @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  // Relationships
  financialContacts FinancialContact[]
  invoices          Invoice[]
  communications    Communication[]
  customerNotes     CustomerNote[]
  tasks             Task[]

  @@index([tenantId])
  @@index([assignedUserId])
  @@map("customers")
}

model FinancialContact {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  customerId  String   @map("customer_id")
  name        String
  email       String
  phone       String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("financial_contacts")
}

model CustomerNote {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  userId     String   @map("user_id") // Who wrote the note
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

// ==========================================
// RECEIVABLES (INVOICES & INSTALLMENTS)
// ==========================================

model Invoice {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  customerId          String   @map("customer_id")
  invoiceNumber       String   @map("invoice_number")
  amount              Float    // Base amount (never updated with fines/interest)
  balanceDue          Float    @map("balance_due") // Remaining amount to be paid
  dueDate             DateTime @map("due_date") // Original due date
  issueDate           DateTime @default(now()) @map("issue_date")
  status              String   @default("OPEN") // OPEN, PAID, CANCELED, PROMISE_TO_PAY
  
  // Payment Details
  paidAt              DateTime? @map("paid_at")
  paidAmount          Float?    @map("paid_amount")
  
  // Cancellation Details
  canceledAt          DateTime? @map("canceled_at")
  cancelReason        String?   @map("cancel_reason")
  
  // Promise to Pay Details
  promiseDate         DateTime? @map("promise_date")
  promiseNote         String?   @map("promise_note")

  // Computed/Expected Values (Can be persisted or recalculated)
  fineAmount          Float    @default(0) @map("fine_amount")
  interestAmount      Float    @default(0) @map("interest_amount")
  updatedAmount       Float    @default(0) @map("updated_amount") // amount + fineAmount + interestAmount

  externalReferenceId String?  @map("external_reference_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Relationships
  installments    InvoiceInstallment[]
  communications  Communication[]
  paymentPromises PaymentPromise[]
  tasks           Task[]

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceInstallment {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  invoiceId        String   @map("invoice_id")
  installmentNumber Int      @map("installment_number")
  amount           Float
  dueDate          DateTime @map("due_date")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_installments")
}

// ==========================================
// AUTOMATION & HISTORY
// ==========================================

model BillingFlow {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  rules       String   // String in SQLite representing Workflow JSON configuration
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("billing_flows")
}

model Communication {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  customerId   String    @map("customer_id")
  invoiceId    String?   @map("invoice_id")
  channel      String    // email, whatsapp, sms, portal_view, system
  messageType  String    @map("message_type") // reminder, late_notice, thank_you, manual_message, payment_confirmed
  content      String
  status       String    @default("queued") // queued, sent, delivered, read, failed
  externalId   String?   @map("external_id")   // Provider message ID (Resend ID, Z-API messageId)
  errorMessage String?   @map("error_message") // Failure detail
  retryCount   Int       @default(0) @map("retry_count")
  sentAt       DateTime  @default(now()) @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Foreign Keys
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, sentAt])
  @@index([externalId])
  @@map("communications")
}

model MessageQueue {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  channel              String    // email | whatsapp
  to                   String    // email address or E.164 phone number
  subject              String?   // email only
  body                 String
  metadata             String?   // JSON: { invoiceId, customerId, messageType, communicationId }
  status               String    @default("queued") // queued | sending | sent | failed | failed_permanent
  retryCount           Int       @default(0) @map("retry_count")
  maxRetries           Int       @default(3) @map("max_retries")
  errorLog             String?   @map("error_log")
  scheduledAt          DateTime  @default(now()) @map("scheduled_at")
  sentAt               DateTime? @map("sent_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  // ── Hardening fields ─────────────────────────────────────────────────────
  idempotencyKey       String?   @unique @map("idempotency_key")  // sha256(tenantId:invoiceId:channel:messageType:day)
  isDlq                Boolean   @default(false) @map("is_dlq")   // true after maxRetries exhausted
  fallbackFrom         String?   @map("fallback_from")             // ID of original queue item (channel fallback)
  nextRetryAt          DateTime? @map("next_retry_at")             // exponential backoff target
  processingStartedAt  DateTime? @map("processing_started_at")     // detect stuck messages

  @@index([status, retryCount])
  @@index([tenantId])
  @@index([idempotencyKey])
  @@index([isDlq])
  @@map("message_queue")
}

model PaymentPromise {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  invoiceId    String   @map("invoice_id")
  userId       String   @map("user_id") // The Operator who got the promise
  promisedDate DateTime @map("promised_date")
  amount       Float
  notes        String?
  status       String   @default("pending") // pending, fulfilled, broken
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([tenantId, promisedDate])
  @@map("payment_promises")
}

model ActivityLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String   // INVOICE_CREATED, PAYMENT_REGISTERED, FLOW_ACTIVATED
  entityType String   @map("entity_type") // invoice, customer, settings
  entityId   String   @map("entity_id")
  metadata   String?  // String in SQLite representing before/after JSON payload
  createdAt  DateTime @default(now()) @map("created_at")

  // Foreign Keys
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ==========================================
// TASKS
// ==========================================

model Task {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  customerId  String    @map("customer_id")
  invoiceId   String?   @map("invoice_id")
  title       String
  description String?
  status      String    @default("pending") // pending, completed, canceled
  dueDate     DateTime  @map("due_date")
  assigneeId  String?   @map("assignee_id")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Foreign Keys
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  assignee User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, dueDate])
  @@index([assigneeId, status])
  @@map("tasks")
}
